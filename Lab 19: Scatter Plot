   ],
   "source": [
    "#Create the scatter plot\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "plt.figure(figsize=(8, 6))\n",
    "plt.scatter(\n",
    "    df_scatter['Age_numeric'],\n",
    "    df_scatter['JobSatPoints_6'],\n",
