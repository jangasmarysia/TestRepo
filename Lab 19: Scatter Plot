    "### Task 4: Scatter Plot Comparisons Across Groups\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "#### 1. Scatter Plot for Compensation vs. Job Satisfaction by Employment Type\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "Visualize the relationship between yearly compensation (`ConvertedCompYearly`) and job satisfaction (`JobSatPoints_6`), categorized by employment type (`Employment`). Use color coding or markers to differentiate between employment types.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 42,
   "metadata": {},
   "outputs": [],
   "source": [
    "#prepare and clean data\n",
    "df_emp_scatter = df[['ConvertedCompYearly', 'JobSatPoints_6', 'Employment']].copy()\n",
    "\n",
    "df_emp_scatter['ConvertedCompYearly'] = pd.to_numeric(\n",
    "    df_emp_scatter['ConvertedCompYearly'], errors='coerce'\n",
    ")\n",
    "df_emp_scatter['JobSatPoints_6'] = pd.to_numeric(\n",
    "    df_emp_scatter['JobSatPoints_6'], errors='coerce'\n",
    ")\n",
    "\n",
    "df_emp_scatter = df_emp_scatter.dropna()\n",
    "    "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 43,
   "metadata": {},
   "outputs": [],
   "source": [
    "#Trim outliers\n",
    "Q1 = df_emp_scatter['ConvertedCompYearly'].quantile(0.25)\n",
    "Q3 = df_emp_scatter['ConvertedCompYearly'].quantile(0.75)\n",
    "IQR = Q3 - Q1\n",
    "upper = Q3 + 1.5 * IQR\n",
    "\n",
    "df_emp_scatter = df_emp_scatter[df_emp_scatter['ConvertedCompYearly'] <= upper]\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 44,
   "metadata": {},
   "outputs": [],
   "source": [
    "#filter to top employment types\n",
    "top_employment = (\n",
    "    df_emp_scatter['Employment']\n",
    "    .value_counts()\n",
    "    .head(4)\n",
    "    .index\n",
    ")\n",
    "\n",
    "df_emp_scatter = df_emp_scatter[\n",
    "    df_emp_scatter['Employment'].isin(top_employment)\n",
    "]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 45,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 900x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "#create scatter plot with color coding and markers\n",
    "markers = ['o', 's', '^', 'D']\n",
    "\n",
    "plt.figure(figsize=(9, 6))\n",
    "\n",
    "for emp, m in zip(top_employment, markers):\n",
    "    subset = df_emp_scatter[df_emp_scatter['Employment'] == emp]\n",
    "    plt.scatter(\n",
    "        subset['ConvertedCompYearly'],\n",
    "        subset['JobSatPoints_6'],\n",
    "        alpha=0.4,\n",
    "        marker=m,\n",
    "        label=emp\n",
    "    )\n",
    "\n",
    "plt.xlabel('Yearly Compensation (USD)')\n",
    "plt.ylabel('Job Satisfaction Score (0–100)')\n",
    "plt.title('Compensation vs Job Satisfaction by Employment Type')\n",
    "plt.legend(fontsize=8)\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
