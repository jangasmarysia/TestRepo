   "source": [
    "#### 2. Scatter Plot for Work Experience vs. Age Group by Country\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "Compare work experience (`YearsCodePro`) across different age groups (`Age`) and countries (`Country`). Use colors to represent different countries and markers for age groups.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 46,
   "metadata": {},
   "outputs": [],
   "source": [
    "#Prepare and clean the data\n",
    "df_exp = df[['Age', 'YearsCodePro', 'Country']].copy()\n",
    "\n",
    "# Remove unusable age values\n",
    "df_exp = df_exp[df_exp['Age'] != 'Prefer not to say']\n",
    "\n",
    "# Convert YearsCodePro to numeric\n",
    "df_exp['YearsCodePro'] = pd.to_numeric(\n",
    "    df_exp['YearsCodePro'], errors='coerce'\n",
    ")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 47,
   "metadata": {},
   "outputs": [],
   "source": [
    "#convert age to numeric\n",
    "age_mapping = {\n",
    "    'Under 18 years old': 16,\n",
    "    '18-24 years old': 21,\n",
    "    '25-34 years old': 30,\n",
    "    '35-44 years old': 40,\n",
    "    '45-54 years old': 50,\n",
    "    '55-64 years old': 60,\n",
    "    '65 years or older': 70\n",
    "}\n",
    "\n",
    "df_exp['Age_numeric'] = df_exp['Age'].map(age_mapping)\n",
    "df_exp['AgeGroup'] = df_exp['Age']\n",
    "\n",
    "df_exp = df_exp.dropna()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 48,
   "metadata": {},
   "outputs": [],
   "source": [
    "#limit to top countries\n",
    "top_countries = (\n",
    "    df_exp['Country']\n",
    "    .value_counts()\n",
    "    .head(4)\n",
    "    .index\n",
    ")\n",
    "\n",
    "df_exp = df_exp[df_exp['Country'].isin(top_countries)]\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 49,
   "metadata": {},
   "outputs": [],
   "source": [
    "#define markers for age groups\n",
    "age_markers = {\n",
    "    '18-24 years old': 'o',\n",
    "    '25-34 years old': 's',\n",
    "    '35-44 years old': '^',\n",
    "    '45-54 years old': 'D',\n",
    "    '55-64 years old': 'P',\n",
    "    '65 years or older': 'X'\n",
    "}\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 54,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1000x700 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "#create scatterplot\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "plt.figure(figsize=(10, 7))\n",
    "\n",
    "for country in top_countries:\n",
    "    for age_group, marker in age_markers.items():\n",
    "        subset = df_exp[\n",
    "            (df_exp['Country'] == country) &\n",
    "            (df_exp['AgeGroup'] == age_group)\n",
    "        ]\n",
    "        \n",
    "        if not subset.empty:\n",
    "            plt.scatter(\n",
    "                subset['Age_numeric'],\n",
    "                subset['YearsCodePro'],\n",
    "                alpha=0.5,\n",
    "                marker=marker,\n",
    "                label=f'{country} – {age_group}'\n",
    "            )\n",
    "\n",
    "plt.xlabel('Age (Approximate)')\n",
    "plt.ylabel('Years of Professional Coding Experience')\n",
    "plt.title('Work Experience by Age Group and Country')\n",
    "\n",
    "# Reduce legend clutter\n",
    "handles, labels = plt.gca().get_legend_handles_labels()\n",
    "plt.legend(\n",
    "    handles[:25], labels[:25],\n",
    "    fontsize=8,\n",
    "    title='Country – Age Group'\n",
    ")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
