  {
   "cell_type": "code",
   "execution_count": 22,
   "metadata": {},
   "outputs": [],
   "source": [
    "#Remove outliers only for correlation analysis\n",
    "df_corr_base = df.copy()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 23,
   "metadata": {},
   "outputs": [],
   "source": [
    "#ensure convertedcompyearly is numeric\n",
    "df_corr_base['ConvertedCompYearly'] = pd.to_numeric(\n",
    "    df_corr_base['ConvertedCompYearly'],\n",
    "    errors='coerce'\n",
    ")\n",
    "\n",
    "df_corr_base = df_corr_base.dropna(subset=['ConvertedCompYearly'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 24,
   "metadata": {},
   "outputs": [],
   "source": [
    "#calculate IQR bounds\n",
    "Q1 = df_corr_base['ConvertedCompYearly'].quantile(0.25)\n",
    "Q3 = df_corr_base['ConvertedCompYearly'].quantile(0.75)\n",
    "\n",
    "IQR = Q3 - Q1\n",
    "\n",
    "lower_bound = Q1 - 1.5 * IQR\n",
    "upper_bound = Q3 + 1.5 * IQR"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 25,
   "metadata": {},
   "outputs": [],
   "source": [
    "#create refined dataframe\n",
    "df_corr_refined = df_corr_base[\n",
    "    (df_corr_base['ConvertedCompYearly'] >= lower_bound) &\n",
    "    (df_corr_base['ConvertedCompYearly'] <= upper_bound)\n",
    "].copy()"
   ]
  },
