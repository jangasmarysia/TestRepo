   "source": [
    "#Calculate the Interquartile Range (IQR)\n",
    "Q1 = df_iqr['ConvertedCompYearly'].quantile(0.25)\n",
    "Q3 = df_iqr['ConvertedCompYearly'].quantile(0.75)\n",
    "\n",
    "IQR = Q3 - Q1\n",
