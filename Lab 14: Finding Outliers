   "source": [
    "#Determine the upper and lower bounds for outliers.\n",
    "lower_bound = Q1 - 1.5 * IQR\n",
    "upper_bound = Q3 + 1.5 * IQR\n",
    "\n",
    "lower_bound, upper_bound\n"
